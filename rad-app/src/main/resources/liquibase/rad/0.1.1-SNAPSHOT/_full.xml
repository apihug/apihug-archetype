  <changeSet id="0.1.1-SNAPSHOT-1000000000" author="hope" context="auto" labels="0.1.1-SNAPSHOT">
    <createTable remarks="HTTP访问审计日志表" tableName="SYS_ACCESS_LOG">
      <column name="ID" type="BIGINT" autoIncrement="true" remarks="Record ID, Primary Key, Auto Increment">
        <constraints nullable="false" primaryKey="true" unique="true"></constraints>
      </column>
      <column name="HTTP_METHOD" type="VARCHAR(10)" remarks="HTTP请求方法">
        <constraints nullable="false"></constraints>
      </column>
      <column name="REQUEST_PATH" type="VARCHAR(500)" remarks="请求路径">
        <constraints nullable="false"></constraints>
      </column>
      <column name="REQUEST_PARAMS" type="CLOB" remarks="脱敏后的请求参数JSON"></column>
      <column name="RESPONSE_STATUS" type="INT" remarks="HTTP响应状态码"></column>
      <column name="START_EPOCH_TS" type="BIGINT" defaultValue="0" remarks="start epoch timestamp">
        <constraints nullable="false"></constraints>
      </column>
      <column name="DURATION_MS" type="BIGINT" defaultValue="0" remarks="请求耗时毫秒"></column>
      <column name="CUSTOMER_ID" type="BIGINT" remarks="客户ID"></column>
      <column name="IP_ADDRESS" type="VARCHAR(45)" remarks="IP地址"></column>
      <column name="USER_AGENT" type="VARCHAR(500)" remarks="用户代理"></column>
      <column name="SERVICE_NAME" type="VARCHAR(255)" remarks="服务名称"></column>
      <column name="METHOD_NAME" type="VARCHAR(125)" remarks="方法名称"></column>
      <column name="ERROR_CODE" type="VARCHAR(50)" remarks="错误码"></column>
      <column name="ERROR_MESSAGE" type="VARCHAR(500)" remarks="错误信息"></column>
      <column name="CHANNEL" type="VARCHAR(16)" defaultValue="API" remarks="渠道">
        <constraints nullable="false"></constraints>
      </column>
      <column name="CREATED_BY" type="BIGINT" remarks="created by">
        <constraints nullable="false"></constraints>
      </column>
      <column name="CREATED_AT" type="DATETIME" remarks="created at timestamp">
        <constraints nullable="false"></constraints>
      </column>
      <column name="PRIORITY" type="VARCHAR(255)" defaultValue="LOW" remarks="priority of this method">
        <constraints nullable="false"></constraints>
      </column>
      <column name="TENANT_ID" type="BIGINT" defaultValue="0" remarks="Record tenant ID"></column>
    </createTable>
    <createIndex tableName="SYS_ACCESS_LOG" indexName="IDX_SYS_ACCESS_LOG_CUSTOMER_ID">
      <column name="CUSTOMER_ID"></column>
    </createIndex>
    <createIndex tableName="SYS_ACCESS_LOG" indexName="IDX_SYS_ACCESS_LOG_REQUEST_PATH">
      <column name="REQUEST_PATH"></column>
    </createIndex>
    <createIndex tableName="SYS_ACCESS_LOG" indexName="IDX_SYS_ACCESS_LOG_CREATED_AT">
      <column name="CREATED_AT"></column>
    </createIndex>
    <createIndex tableName="SYS_ACCESS_LOG" indexName="IDX_SYS_ACCESS_LOG_TENANT_ID_CREATED_AT">
      <column name="TENANT_ID"></column>
      <column name="CREATED_AT"></column>
    </createIndex>
  </changeSet>
